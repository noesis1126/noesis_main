# EmailJS (https://www.emailjs.com) - free tier, client-side email sending
# 1. Create an account and add an Email Service (connect noesis1126@gmail.com) -> copy the Service ID
# 2. Create two templates:
#    - Admin notification template (sent to you) -> copy its Template ID
#    - User auto-reply/thank-you template (sent to the form's email field) -> copy its Template ID
# 3. Account > General > copy your Public Key
VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_ADMIN_TEMPLATE_ID=your_admin_template_id
VITE_EMAILJS_USER_TEMPLATE_ID=your_user_template_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key
